# AtmosphereAI — Environment Variables
# Copy this file to .env and fill in your API keys

# MongoDB Connection URI
# For local: mongodb://localhost:27017/atmosphereAI
# For Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/atmosphereAI
MONGO_URI=mongodb://localhost:27017/atmosphereAI

# OpenWeatherMap API Key (free tier: https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_key_here

# YouTube Data API v3 Key (Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_key_here

# Google Maps Embed API Key (Google Cloud Console — free, unlimited)
GOOGLE_MAPS_KEY=your_google_maps_key_here

# Gemini API Key (optional — Google AI Studio)
GEMINI_API_KEY=your_gemini_key_here

# Server Port
PORT=5000
